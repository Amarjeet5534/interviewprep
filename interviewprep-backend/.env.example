# Backend Environment Configuration Template

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/interviewprep_db
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production-to-at-least-256-bits
JWT_EXPIRATION=86400000

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_INTERVIEWPREP=DEBUG
